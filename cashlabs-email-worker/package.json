{
  "name": "cashlabs-email-worker",
  "version": "1.0.0",
  "description": "CashLabs async email delivery worker — consumes Kafka events and sends emails via SendGrid",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "start": "node dist/worker.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "dotenv": "^16.4.5",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
